{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore": "Warning",
            "realestate_ia_site.Server": "Information",
            "realestate_ia_site.Server.Application.Security": "Information",
            "realestate_ia_site.Server.Controllers": "Information",
            "realestate_ia_site.Server.Middleware": "Information"
        },
        "Console": {
            "IncludeScopes": true,
            "TimestampFormat": "[yyyy-MM-dd HH:mm:ss] "
        },
        "ApplicationInsights": {
            "LogLevel": {
                "Default": "Information",
                "Microsoft": "Warning"
            }
        }
    },
    "AllowedHosts": "residai-server.azurewebsites.net",
    "OpenAI": {
        "Model": "gpt-4o-mini"
    },
    "Email": {
        "SmtpHost": "smtp.gmail.com",
        "SmtpPort": 587,
        "EnableSsl": true,
        "DefaultFromEmail": "noreply@residai.com",
        "DefaultFromName": "ResidAI"
    },
    "Jwt": {
        "Issuer": "ResidAI",
        "Audience": "ResidAI-Users",
        "ExpiryMinutes": "60"
    },
    "App": {
        "BaseUrl": "https://residai-server.azurewebsites.net"
    },
    "Security": {
        "EnableSecurityHeaders": true,
        "EnableRateLimiting": true,
        "EnableSecurityLogging": true
    },
    "Features": {
        "EnableTwoFactorAuth": true,
        "EnableCaptcha": true,
        "EnableIpWhitelist": false
    }
}