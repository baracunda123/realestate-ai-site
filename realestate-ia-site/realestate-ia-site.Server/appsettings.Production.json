{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore": "Warning",
            "realestate_ia_site.Server.Application.Security": "Information"
        }
    },
    "AllowedHosts": "residai-server.azurewebsites.net",
    "OpenAI": {
        "Model": "gpt-4o-mini"
    },
    "Stripe": {
        "SuccessUrl": "https://residai-server.azurewebsites.net/subscription/success",
        "CancelUrl": "https://residai-server.azurewebsites.net/subscription/cancel"
    },
    "Email": {
        "SmtpHost": "smtp.gmail.com",
        "SmtpPort": 587,
        "EnableSsl": true,
        "DefaultFromEmail": "noreply@residai.com",
        "DefaultFromName": "ResidAI"
    },
    "Jwt": {
        "Issuer": "ResidAI",
        "Audience": "ResidAI-Users",
        "ExpiryMinutes": "60"
    },
    "App": {
        "BaseUrl": "https://residai-server.azurewebsites.net"
    },
    "Security": {
        "EnableSecurityHeaders": true,
        "EnableRateLimiting": true,
        "EnableSecurityLogging": true
    },
    "Features": {
        "EnableTwoFactorAuth": true,
        "EnableCaptcha": true,
        "EnableIpWhitelist": false
    }
}